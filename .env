# ===== Image tags (loaded from ./image/*.tar via docker load) =====
GITLAB_IMAGE=gitlab/gitlab-ee:latest
REDMINE_IMAGE=redmine:5

# ===== GitLab =====
GITLAB_HOSTNAME=gitlab.local
GITLAB_HTTP_PORT=80
GITLAB_HTTPS_PORT=443
GITLAB_SSH_PORT=2222

# ===== Redmine =====
REDMINE_PORT=3000

# ===== UID/GID (GitLab Omnibus の git ユーザに合わせる) =====
GIT_UID=998
GIT_GID=998
